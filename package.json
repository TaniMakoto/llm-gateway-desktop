{
  "name": "llm-gateway-desktop",
  "version": "0.1.0-alpha.6",
  "description": "A local desktop gateway for routing and translating OpenAI- and Anthropic-compatible LLM APIs.",
  "type": "module",
  "scripts": {
    "dev": "pnpm tauri dev",
    "build": "pnpm tauri build",
    "tauri": "tauri",
    "dev:renderer": "vite",
    "build:renderer": "vite build",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\""
  },
  "keywords": [
    "llm",
    "api-gateway",
    "openai",
    "anthropic",
    "tauri",
    "desktop",
    "proxy"
  ],
  "author": "LLM Gateway Desktop contributors",
  "license": "MIT",
  "devDependencies": {
    "@tauri-apps/cli": "^2.8.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prettier": "^3.9.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.3.0",
    "vite": "^7.3.0"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.8.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.25.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1"
  }
}
